        <li><a href="/machines#plasma">CNC Plasma Tables</a></li>
        <li><a href="/machines#lasers">Laser Systems</a></li>
        <li><a href="/machines#custom">Custom Builds</a></li>
        <li><a href="/financing">Financing</a></li>
      </ul>
