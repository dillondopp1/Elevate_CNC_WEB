---
import Layout from '../layouts/Layout.astro';
import {
  fetchZohoItems,
  categorizeMachines,
  monthlyPayment,
  getWorkingArea,
  getSeries,
  getSize,
} from '../lib/zoho.js';

const items = await fetchZohoItems();
const { plasma, routers, specialty } = categorizeMachines(items);

/* ── Helpers ─────────────────────────────────────── */
function fmt(n) {
  return '$' + Number(n).toLocaleString('en-US');
}

function groupBySeries(machines) {
  const map = {};
  machines.forEach(m => {
    const key = getSeries(m.name);
    if (!map[key]) map[key] = [];
    map[key].push(m);
  });
  Object.values(map).forEach(arr => arr.sort((a, b) => a.rate - b.rate));
  return map;
}

/* ── Group by series ─────────────────────────────── */
const plasmaByS = groupBySeries(plasma);
const routerByS = groupBySeries(routers);
const specByS   = groupBySeries(specialty);

const plasmaSeries = ['Spark Series','ION Series','Prime Series'].filter(s => plasmaByS[s]);
const routerSeries = ['Ascent Series','Ridge Series','Summit Series','Summit ATC','Apex Series'].filter(s => routerByS[s]);
const specSeries   = ['Summit Lathe','BoreLine'].filter(s => specByS[s]);

/* ── Series metadata ─────────────────────────────── */
const META = {
  'Spark Series':  { badge:'ENTRY',       cls:'badge-entry',      tagline:'Entry-Level Plasma Table',            intro:'Compact, affordable plasma tables for hobbyists, makers, and small shops. Touchscreen control, Wi-Fi, USB, and TF card support — no computer required during operation.' },
  'ION Series':    { badge:'MID-TIER',    cls:'badge-mid',        tagline:'Mid-Tier CNC Plasma Table',           intro:'Upgraded from the Spark with NEMA 23 motors, 20 mm timing belts, and a motorized Z-axis with floating touch-off for automatic material sensing and better cut consistency.' },
  'Prime Series':  { badge:'PRODUCTION',  cls:'badge-pro',        tagline:'Production-Grade Plasma Table',       intro:'Production-ready with integrated Torch Height Control (THC), rack-and-pinion drive on all axes, and travel speeds up to 800 IPM. Optional water table upgrade available.' },
  'Ascent Series': { badge:'ENTRY',       cls:'badge-entry',      tagline:'Entry-Level CNC Router',              intro:'Runs on standard 110V household power — no industrial electrical service required. Welded steel base, aluminum extrusion gantry, FluidNC control. A real CNC platform, not a kit.' },
  'Ridge Series':  { badge:'MID-RANGE',   cls:'badge-mid',        tagline:'Extrusion-Based CNC Router',          intro:'Rigid aluminum extrusion frame with rack-and-pinion drive and Centroid CNC12 control. X/Y resolution to 0.0005". Modular design supports future upgrades and custom configurations.' },
  'Summit Series': { badge:'PRODUCTION',  cls:'badge-pro',        tagline:'Industrial Production CNC Router',    intro:'Fully welded steel frame, helical rack-and-pinion drive, full vacuum table, auto-lubrication, and Centroid CNC12. Built for cabinet shops and sign makers who need daily reliability.' },
  'Summit ATC':    { badge:'PRODUCTION+', cls:'badge-pro',        tagline:'Summit with Automatic Tool Change',   intro:'The full Summit platform upgraded with a 6HP ATC spindle, 8-position linear tool rack, BT30/ER25 holders, and automatic tool length setter. Compressed air required for operation.' },
  'Apex Series':   { badge:'INDUSTRIAL',  cls:'badge-industrial', tagline:'Industrial Production CNC Router',    intro:'1500W AC servo motors with closed-loop feedback, 12HP spindle, 1,200 IPM rapid speed, centralized auto-lubrication, and Centroid CNC12. The flagship router in the Elevate CNC lineup.' },
  'BoreLine':      { badge:'SPECIALTY',   cls:'badge-specialty',  tagline:'Double-Head Side Hole Drilling',      intro:'Purpose-built for production cabinet and furniture shops. Dual 3HP horizontal spindles, laser probe positioning, barcode scanning, and pneumatic material clamping. 110 in operating stroke.' },
  'Summit Lathe':  { badge:'SPECIALTY',   cls:'badge-specialty',  tagline:'CNC Wood Lathe',                      intro:'One-piece cast iron bed with Taiwan Hiwin rails, TBI ballscrews, and a 7.4HP main motor. Optional lengths to 118 in. Designed for furniture makers, stair builders, and column shops.' },
};
---

<Layout title="CNC Machines" description="Full Elevate CNC machine lineup — Plasma Tables (Spark, ION, Prime), CNC Routers (Ascent, Ridge, Summit, Apex), and Specialty Machines." currentPage="/machines">

  <!-- HERO -->
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="page-hero-label">// Full Machine Lineup</p>
      <h1 class="page-hero-title">Find Your Machine</h1>
      <p class="page-hero-sub">Select a series to see sizes and pricing — all pulled live from our inventory.</p>
    </div>
  </div>

  <!-- CATEGORY JUMP NAV -->
  <nav class="cat-nav" aria-label="Machine categories">
    <div class="container">
      <div class="cat-nav-inner">
        <a href="#plasma"    class="cat-nav-item">Plasma Tables</a>
        <a href="#routers"   class="cat-nav-item">CNC Routers</a>
        <a href="#specialty" class="cat-nav-item">Specialty Machines</a>
        <a href="#custom"    class="cat-nav-item">Custom Builds</a>
      </div>
    </div>
  </nav>

  <!-- ══════════════════════════════════════════════ -->
  <!-- PLASMA TABLES                                  -->
  <!-- ══════════════════════════════════════════════ -->
  <section id="plasma" class="machine-section" style="background: var(--white);">
    <div class="container">
      <p class="section-label">// Plasma Tables</p>
      <h2 class="section-title">Cut Steel, Aluminum & Sheet Metal</h2>
      <div class="title-rule"></div>
      <p class="section-sub">Three tiers — from compact garage tables to production shop setups. Click a series to see available sizes and pricing.</p>

      <div class="series-list">
        {plasmaSeries.map(seriesKey => {
          const variants = plasmaByS[seriesKey];
          const meta     = META[seriesKey];
          const minPrice = Math.min(...variants.map(v => v.rate));
          const maxPrice = Math.max(...variants.map(v => v.rate));
          return (
            <div class="series-accordion">
              <button class="series-toggle" aria-expanded="false">
                <div class="stl">
                  <span class={`s-badge ${meta.cls}`}>{meta.badge}</span>
                  <div>
                    <div class="s-name">{seriesKey}</div>
                    <div class="s-tag">{meta.tagline}</div>
                  </div>
                </div>
                <div class="str">
                  <span class="s-price">
                    {variants.length > 1
                      ? `${fmt(minPrice)} – ${fmt(maxPrice)}`
                      : fmt(minPrice)
                    }
                    {variants.length > 1 && <span class="s-count"> · {variants.length} sizes</span>}
                  </span>
                  <svg class="s-chevron" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </button>

              <div class="series-body" hidden>
                <p class="s-intro">{meta.intro}</p>
                <div class="variants-grid">
                  {variants.map(v => {
                    const size = getSize(v.name);
                    const area = getWorkingArea(v.description);
                    const mo   = monthlyPayment(v.rate);
                    return (
                      <div class="variant-card">
                        <div class="vc-size">{size}</div>
                        {area && <div class="vc-area">{area} cutting area</div>}
                        <div class="vc-price">{fmt(v.rate)}</div>
                        {v.rate >= 1000 && <div class="vc-monthly">Est. {fmt(mo)}/mo*</div>}
                        <a href="/#contact" class="btn btn-primary vc-btn">Get a Quote</a>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ -->
  <!-- CNC ROUTERS                                    -->
  <!-- ══════════════════════════════════════════════ -->
  <section id="routers" class="machine-section" style="background: var(--light);">
    <div class="container">
      <p class="section-label">// CNC Routers</p>
      <h2 class="section-title">From Entry-Level to Industrial</h2>
      <div class="title-rule"></div>
      <p class="section-sub">Four series covering every budget and production level. Every router ships with a welded steel frame, precision components, and full support.</p>

      <div class="series-list">
        {routerSeries.map(seriesKey => {
          const variants = routerByS[seriesKey];
          const meta     = META[seriesKey];
          const minPrice = Math.min(...variants.map(v => v.rate));
          const maxPrice = Math.max(...variants.map(v => v.rate));
          return (
            <div class="series-accordion">
              <button class="series-toggle" aria-expanded="false">
                <div class="stl">
                  <span class={`s-badge ${meta.cls}`}>{meta.badge}</span>
                  <div>
                    <div class="s-name">{seriesKey}</div>
                    <div class="s-tag">{meta.tagline}</div>
                  </div>
                </div>
                <div class="str">
                  <span class="s-price">
                    {variants.length > 1
                      ? `${fmt(minPrice)} – ${fmt(maxPrice)}`
                      : fmt(minPrice)
                    }
                    {variants.length > 1 && <span class="s-count"> · {variants.length} configs</span>}
                  </span>
                  <svg class="s-chevron" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </button>

              <div class="series-body" hidden>
                <p class="s-intro">{meta.intro}</p>
                <div class="variants-grid">
                  {variants.map(v => {
                    const size = getSize(v.name);
                    const area = getWorkingArea(v.description);
                    const mo   = monthlyPayment(v.rate);
                    return (
                      <div class="variant-card">
                        <div class="vc-size">{size}</div>
                        {area && <div class="vc-area">{area} working area</div>}
                        <div class="vc-price">{fmt(v.rate)}</div>
                        <div class="vc-monthly">Est. {fmt(mo)}/mo*</div>
                        <a href="/#contact" class="btn btn-primary vc-btn">Get a Quote</a>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ -->
  <!-- SPECIALTY                                       -->
  <!-- ══════════════════════════════════════════════ -->
  <section id="specialty" class="machine-section" style="background: var(--dark-2);">
    <div class="container">
      <p class="section-label" style="color: var(--accent);">// Specialty Machines</p>
      <h2 class="section-title white">Purpose-Built Operations</h2>
      <div class="title-rule"></div>
      <p class="section-sub" style="color: #aaa;">Not general routing — dedicated industrial machines built for specific, high-volume operations.</p>

      <div class="series-list series-list-dark">
        {specSeries.map(seriesKey => {
          const variants = specByS[seriesKey];
          const meta     = META[seriesKey];
          const minPrice = Math.min(...variants.map(v => v.rate));
          return (
            <div class="series-accordion series-accordion-dark">
              <button class="series-toggle" aria-expanded="false">
                <div class="stl">
                  <span class={`s-badge ${meta.cls}`}>{meta.badge}</span>
                  <div>
                    <div class="s-name">{seriesKey}</div>
                    <div class="s-tag">{meta.tagline}</div>
                  </div>
                </div>
                <div class="str">
                  <span class="s-price">{fmt(minPrice)}</span>
                  <svg class="s-chevron" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </button>

              <div class="series-body" hidden>
                <p class="s-intro">{meta.intro}</p>
                <div class="variants-grid">
                  {variants.map(v => {
                    const size = getSize(v.name);
                    const area = getWorkingArea(v.description);
                    const mo   = monthlyPayment(v.rate);
                    return (
                      <div class="variant-card">
                        <div class="vc-size">{size}</div>
                        {area && <div class="vc-area">{area}</div>}
                        <div class="vc-price">{fmt(v.rate)}</div>
                        <div class="vc-monthly">Est. {fmt(mo)}/mo*</div>
                        <a href="/#contact" class="btn btn-primary vc-btn">Get a Quote</a>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ -->
  <!-- CUSTOM CTA                                      -->
  <!-- ══════════════════════════════════════════════ -->
  <section id="custom" style="padding: var(--section-pad); background: var(--dark);">
    <div class="container text-center">
      <p class="section-label">// Custom</p>
      <h2 class="section-title white">Don't See Exactly What You Need?</h2>
      <div class="title-rule"></div>
      <p class="section-sub" style="color: #aaa;">
        We configure machines to your exact specs — table size, drive system, spindle, software,
        accessories, and tooling. Tell us your workflow and we'll build the right machine.
      </p>
      <a href="/#contact" class="btn btn-primary" style="margin-top: 32px;">Talk to Us About a Custom Build</a>
    </div>
  </section>

  <!-- Financing footnote -->
  <div style="background: var(--light); padding: 16px 24px; text-align: center;">
    <p style="font-size: 0.8rem; color: var(--text-muted);">
      *Monthly payment estimates based on 60-month term at ~8% APR. Subject to credit approval. Contact us for financing details.
    </p>
  </div>

  <script>
    // Accordion — one open per section
    document.querySelectorAll('.series-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const body   = btn.nextElementSibling;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        const list   = btn.closest('.series-list');

        // Close all in same list
        list.querySelectorAll('.series-toggle').forEach(b => {
          b.setAttribute('aria-expanded', 'false');
          b.nextElementSibling.hidden = true;
        });

        // Open this one if it was closed
        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          body.hidden = false;
          setTimeout(() => body.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
        }
      });
    });
  </script>

</Layout>
